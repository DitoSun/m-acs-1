# M-ACS-1 Configuration
# Auto-loaded by Docker Compose. Override with environment: in docker-compose.yml

# -- Ollama --
OLLAMA_URL=http://ollama:11434

# -- GPU Metrics --
GPU_METRICS_FILE=/data/gpu.json
METRICS_STALE_SECONDS=5

# -- Host Agent --
COLLECTOR_POLL_INTERVAL=2

# -- Control Plane --
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8080

# -- Optional Services --
INSTALL_OPEN_WEBUI=false
